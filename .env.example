# Email delivery for the contact form (optional but recommended).
# Sign up at https://resend.com, verify your domain, then set:
RESEND_API_KEY=
# Destination inbox (defaults to hello@deeprun.co.nz if unset):
CONTACT_TO=hello@deeprun.co.nz
# Verified sender on your domain, e.g. "Deep Run <enquiries@deeprun.co.nz>".
# Until your domain is verified you can use "Deep Run <onboarding@resend.dev>".
CONTACT_FROM=Deep Run <onboarding@resend.dev>

# NEVER set this in production - it disables the audit SSRF host check and
# is only for the local Playwright test suite auditing fixtures on 127.0.0.1.
# AUDIT_ALLOW_LOCAL=1
